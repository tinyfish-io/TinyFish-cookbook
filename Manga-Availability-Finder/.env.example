# Copy to .env.local and fill in. The local API (server/index.mjs) loads .env.local via dotenv.

# TinyFish — required for /api/search-manga (browser automation)
# https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=your_tinyfish_api_key

# Google Gemini — optional; improves /api/discover-manga-sites. If unset, built-in fallback site URLs are used.
# https://makersuite.google.com
GEMINI_API_KEY=your_gemini_api_key

# Local API listen port (default 8787)
PORT=8787
