# GitHub App credentials
# Get these from: github.com → Settings → Developer Settings → GitHub Apps → your app

# The numeric App ID shown on your GitHub App's settings page
GITHUB_APP_ID=

# The secret you set when creating the webhook
GITHUB_WEBHOOK_SECRET=

# Path to the private key .pem file you downloaded from GitHub App settings
GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# TinyFish API key — get one free at https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=

# Port (optional, defaults to 3000)
PORT=3000
