# ─── BundleRadar ───────────────────────────────────────────
# Local: copy to .env.local. Vercel: set in Project → Settings → Environment Variables.

# Database (Neon recommended for Vercel) — required for scans, history, quota
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Mino / TinyFish Web Agent (server-only, never exposed to client)
TINYFISH_API_KEY=your_tinyfish_api_key_here
# MINO_BASE_URL=https://agent.tinyfish.ai

# OpenAI (server-only)
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Optional: Stripe (billing), Upstash (rate limit), Inngest (background jobs)
# STRIPE_SECRET_KEY=...
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...
