{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/discord.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/discord", "destination": "/api/discord" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
