# Required: TinyFish (Search API for URL discovery + Fetch API for page content)
# https://agent.tinyfish.ai/api-keys
TINYFISH_API_KEY=your_tinyfish_api_key

# Required for skill synthesis and optional LLM fallback when Search returns no URLs
# Use either OpenAI or OpenRouter (or both; OpenAI is preferred when set)
OPENAI_API_KEY=your_openai_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
